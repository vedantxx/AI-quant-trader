# Streamlit secrets template.
# Do NOT commit real values. On Streamlit Community Cloud, paste these into
# the app's Settings -> Secrets box. Locally, copy to .streamlit/secrets.toml
# (gitignored) if you want to test the password gate.

# Alpaca PAPER keys (keep paper_trading: true in config/settings.yaml)
ALPACA_API_KEY = "your_paper_api_key"
ALPACA_SECRET_KEY = "your_paper_secret_key"

# Password gate for the hosted dashboard (anyone with the URL needs this).
APP_PASSWORD = "choose-a-strong-password"
