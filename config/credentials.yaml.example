# Copy to credentials.yaml and fill in. credentials.yaml is gitignored.
# Prefer .env for secrets; this file exists for non-secret broker/service config
# you don't want committed.

alpaca:
  api_key: your_key_here
  secret_key: your_secret_here
  paper: true
  base_url: https://paper-api.alpaca.markets   # live: https://api.alpaca.markets
  data_url: https://data.alpaca.markets

alerts:
  email:
    enabled: false
    smtp_host: smtp.gmail.com
    smtp_port: 587
    username: you@example.com
    password: app_password_here
    to: [you@example.com]
  webhook:
    enabled: false
    url: https://hooks.slack.com/services/XXX/YYY/ZZZ
